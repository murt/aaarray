{
    "files": ["src/index.ts", "src/types.ts", "src/utils.ts", "src/decorators.ts"],
    "compilerOptions": {
        "module": "ES2022",
        "moduleResolution": "bundler",
        "target": "ES2022",
        "lib": ["ES2022"],
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strict": true,
        "preserveConstEnums": true,
        "inlineSources": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist"
    }
}

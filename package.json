    "main": "dist/aaarray.js",
    "types": "dist/aaarray.d.ts",
    "scripts": {
        "clean": "del-cli dist coverage junit.xml",
        "build": "webpack",
        "test": "npm-run-all --serial clean test:lint build test:unit",
        "test:lint": "eslint src test --ext .ts",
        "test:unit": "jest --reporters default --reporters jest-junit --ci --runInBand --testPathIgnorePatterns browser.test.ts",
        "test:browser": "jest --reporters default --ci --runInBand --collect-coverage=false test/browser.test.ts"
    },
    "devDependencies": {
        "@eslint/js": "9.39.0",
        "@types/jest": "30.0.0",
        "@types/node": "24.9.2",
        "@types/node-static": "0.7.12",
        "@types/selenium-webdriver": "4.35.3",
        "@typescript-eslint/eslint-plugin": "8.46.2",
        "@typescript-eslint/parser": "8.46.2",
        "chromedriver": "142.0.0",
        "del-cli": "7.0.0",
        "eslint": "9.39.0",
        "geckodriver": "6.0.2",
        "jest": "30.2.0",
        "jest-junit": "16.0.0",
        "node-static": "0.7.11",
        "npm-run-all": "4.1.5",
        "selenium-webdriver": "4.38.0",
        "ts-jest": "29.4.5",
        "ts-loader": "9.5.4",
        "typescript": "5.9.3",
        "typescript-eslint": "8.46.2",
        "webpack": "5.102.1",
        "webpack-cli": "6.0.1"
    }
